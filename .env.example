# Firebase Configuration — replace with your own Firebase project values
# Create a Firebase project at https://console.firebase.google.com
# Then enable Authentication (Google + Email/Password) and Firestore Database

# Client-side Firebase config (safe to expose — restricted by Security Rules)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Server-side Firebase Admin SDK credentials
# Download service-account JSON from Firebase Console → Project Settings → Service Accounts
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# OR provide a file path
# FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/service-account.json

# Org defaults (shown in UI)
NEXT_PUBLIC_ORG_NAME=My Community
