rules_version = '2';

// White-label multi-org Firestore Security Rules
// Admins are identified by a Firestore document role field.
// The server-side API routes use firebase-admin SDK which bypasses these rules.

function isAuthenticated() {
  return request.auth != null;
}

function isAdmin() {
  return isAuthenticated() && get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role == "admin";
}

function belongsToOrg(orgId) {
  return isAuthenticated() && request.auth.token.orgId == orgId;
}

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Orgs collection ----
    match /orgs/{orgId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.token.orgId == orgId;
    }

    // ---- Content collections (scoped by orgId) ----
    function isOrgDoc() {
      return resource.data.orgId == request.auth.token.orgId;
    }

    function incomingOrgDoc() {
      return request.resource.data.orgId == request.auth.token.orgId;
    }

    match /events/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /news/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /programs/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /members/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /documents/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /pages/{docId} {
      allow read: if true;  // public
      allow write: if isAdmin();
    }

    match /committee_members/{docId} {
      allow read: if true;  // public
      allow write: if isAdmin();
    }

    match /sponsors/{docId} {
      allow read: if true;  // public
      allow write: if isAdmin();
    }

    // Invitations — admin create, public read by token, admin list/delete
    match /invitations/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow write: if isAdmin();
      allow delete: if isAdmin();
    }

    // Public site reads
    match /public_site/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
